#! /bin/bash

set -xe


#	add add AppImages.

mkdir -p /Applications
mkdir -p /etc/skel/Applications
mkdir -p /etc/skel/.local/bin


{
	printf "%s %s\n" \
		appimagetool		"https://github.com/probonopd/go-appimage/releases/download/continuous/appimaged-640-aarch64.AppImage"

	printf "%s %s\n" \
		buho				"https://download.kde.org/stable/maui/buho/1.2.1/buho-v1.2.1-arm64.AppImage" \
		index				"https://download.kde.org/stable/maui/index/1.2.1/index-v1.2.1-arm64.AppImage" \
		nota				"https://download.kde.org/stable/maui/nota/1.2.1/nota-v1.2.1-arm64.AppImage" \
		pix					"https://download.kde.org/stable/maui/pix/1.2.1/pix-v1.2.1-arm64.AppImage" \
		station				"https://download.kde.org/stable/maui/1.2.0/appimages/station-stable-v1.2-arm64.AppImage" \
		vvave				"https://download.kde.org/stable/maui/vvave/1.2.1/vvave-v1.2.1-arm64.AppImage" \
		clip				"https://download.kde.org/stable/maui/clip/1.1.0/clip-v1.1.0-arm64.AppImage" \
		shelf				"https://download.kde.org/stable/maui/shelf/1.1.0/shelf-v1.1.0-arm64.AppImage"
} | {
	while read name url; do
		axel -a -q -o /Applications/$name "$url"
	done
}

chmod +x /Applications/*

